---
import type { MasterClassRef } from "@/lib/navigation";
import { IconArrowRight, IconPresentation } from "@tabler/icons-react";
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
  CardFooter,
} from "@/components/ui/card";

interface Props {
  masterClass: MasterClassRef;
}

const { masterClass } = Astro.props;
---

<Card
  className="index-master-class-card group h-full border border-border/70 bg-background/70 hover:border-foreground/20"
  role="article"
  aria-labelledby={`mc-title-${masterClass.slug}`}
>
  <CardHeader className="border-b border-border pb-4">
    <div class="mb-2 flex items-center gap-2">
      <span
        class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-200 group-hover:bg-primary/20"
        aria-hidden="true"
      >
        <IconPresentation size={16} aria-hidden="true" />
      </span>
      <span
        class="font-mono text-[10px] font-medium uppercase tracking-widest text-muted-foreground"
      >
        Workshop
      </span>
    </div>
    <CardTitle
      className="pr-2 text-base font-semibold leading-tight text-foreground transition-colors duration-200 group-hover:text-primary"
    >
      <h3
        id={`mc-title-${masterClass.slug}`}
        class="m-0 text-inherit font-inherit"
      >
        <a
          href={masterClass.path}
          aria-label={`View notes for ${masterClass.title}`}
          class="cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded py-1"
        >
          {masterClass.title}
        </a>
      </h3>
    </CardTitle>
  </CardHeader>

  <CardContent className="pt-3">
    {
      masterClass.speakers && masterClass.speakers.length > 0 ? (
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-muted-foreground">
          {masterClass.speakers.map((s) => (
            <span>
              <span class="font-medium text-foreground">{s.name}</span>
              <span class="text-muted-foreground"> — {s.title}</span>
            </span>
          ))}
        </div>
      ) : (
        <p class="text-sm text-muted-foreground leading-relaxed">
          Focused session from industry experts. Notes and key takeaways inside.
        </p>
      )
    }
  </CardContent>

  <CardFooter
    className="mt-auto flex flex-wrap items-center justify-between gap-x-3 gap-y-1 border-t border-border text-xs py-2 bg-[color:var(--color-cta)] hover:opacity-95 text-white transition-opacity"
  >
    <a
      href={masterClass.path}
      aria-label={`View notes for ${masterClass.title}`}
      class="flex w-full items-center justify-between gap-2 font-semibold text-inherit hover:opacity-90 transition-opacity focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded py-1"
    >
      <span>View notes</span>
      <IconArrowRight
        size={16}
        className="shrink-0 transition-transform duration-200 group-hover:translate-x-0.5"
        aria-hidden="true"
      />
    </a>
  </CardFooter>
</Card>
