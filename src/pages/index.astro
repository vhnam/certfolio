---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { buildCertListFromData, buildMasterClassList } from "@/lib/navigation";
import type { CertificatesJson } from "@/lib/navigation";
import certificatesData from "@/data/certificates.json";
import { IconArrowRight, IconExternalLink } from "@tabler/icons-react";
import {
  Card,
  CardHeader,
  CardTitle,
  CardAction,
  CardDescription,
  CardContent,
  CardFooter,
} from "@/components/ui/card";
import { cn } from "@/lib/utils";

const certs = buildCertListFromData(certificatesData as CertificatesJson);

const masterClassEntries = await getCollection("masterClass").catch(() => []);
const masterClasses = buildMasterClassList(masterClassEntries).sort((a, b) =>
  a.title.localeCompare(b.title),
);

/** Truncate description to ~2 lines for card preview */
function truncateDescription(
  text: string | undefined,
  maxLength = 120,
): string {
  if (!text) return "";
  if (text.length <= maxLength) return text;
  return (
    text
      .slice(0, maxLength)
      .trim()
      .replace(/\s+\S*$/, "") + "…"
  );
}

/** Format completed date for display (already a string like "Oct 31, 2025") */
function formatCompletedDate(date: string | null | undefined): string {
  return date ?? "";
}
---

<Layout
  title="Homepage"
  description="Notes and learnings from professional certificates."
>
  <article class="index-page">
    <!-- Hero -->
    <header
      class="relative mb-16 overflow-hidden rounded-2xl bg-gradient-to-br from-muted/60 via-background to-muted/30 px-6 py-12 md:px-10 md:py-16"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,var(--muted)_0%,transparent_70%)] opacity-80"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <p
          class="mb-3 font-mono text-sm font-medium uppercase tracking-widest text-muted-foreground"
        >
          Notes & learnings
        </p>
        <h1
          class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl"
        >
          Certfolio
        </h1>
        <div class="mt-4 h-1 w-16 rounded-full bg-primary" aria-hidden="true">
        </div>
        <p
          class="mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground md:text-xl"
        >
          Structured notes and key learnings from professional design and
          technology certificates. Select a certificate below to explore the
          content.
        </p>
      </div>
    </header>

    <!-- Certificates -->
    <section class="mb-14" aria-labelledby="certificates-heading">
      <p
        class="mb-1 font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
      >
        Explore
      </p>
      <h2
        id="certificates-heading"
        class="text-2xl font-bold tracking-tight text-foreground mb-6"
      >
        Certificates
      </h2>
      {
        certs.length === 0 ? (
          <p class="text-muted-foreground">No certificates found.</p>
        ) : (
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-6" role="list">
            {certs.map((cert, i) => (
              <li class="index-card-wrap" style={`--stagger: ${i}`}>
                <Card
                  className="index-cert-card group border-border shadow-sm transition-[border-color,box-shadow,background-color] duration-200 hover:border-primary/50 hover:bg-accent/30 hover:shadow-md"
                  role="article"
                  aria-labelledby={`cert-title-${cert.slug}`}
                >
                  <CardHeader className="border-b border-border pb-4">
                    <CardTitle className="pr-2 text-base font-semibold leading-tight text-foreground transition-colors duration-200 group-hover:text-primary">
                      <h3
                        id={`cert-title-${cert.slug}`}
                        class="m-0 text-inherit font-inherit"
                      >
                        <a
                          href={`/certificates/${cert.slug}`}
                          class="cursor-pointer focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded py-1"
                        >
                          {cert.title}
                        </a>
                      </h3>
                    </CardTitle>
                  </CardHeader>
                  {cert.description && (
                    <CardDescription className="line-clamp-2 leading-relaxed px-4">
                      {truncateDescription(cert.description)}
                    </CardDescription>
                  )}

                  <CardContent className="flex flex-col gap-2 pt-0">
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted-foreground">
                      <a
                        href={cert.courseLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`Open course page for ${cert.title} (opens in new tab)`}
                        class="hover:text-foreground underline decoration-muted-foreground/50 underline-offset-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded py-2 min-h-[44px] items-center inline-flex"
                      >
                        Course link
                      </a>
                      {cert.completed && (
                        <a
                          href={`/certificates/${cert.slug}`}
                          aria-label={`View notes for ${cert.title}`}
                          class="hover:text-foreground underline decoration-muted-foreground/50 underline-offset-2 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded py-2 min-h-[44px] items-center inline-flex"
                        >
                          View notes
                        </a>
                      )}
                    </div>
                  </CardContent>

                  <CardFooter
                    className={cn(
                      "flex flex-wrap items-center justify-between gap-x-3 gap-y-1 border-border text-xs py-2",
                      {
                        ["bg-red-500 dark:bg-red-400 text-white"]:
                          cert.completed,
                      },
                    )}
                  >
                    {cert.completed ? (
                      <>
                        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                          {cert.completedDate && (
                            <span
                              class="font-mono"
                              aria-label={`Completed ${cert.completedDate}`}
                            >
                              {formatCompletedDate(cert.completedDate)}
                            </span>
                          )}
                          {cert.certificateLink && (
                            <a
                              href={cert.certificateLink}
                              target="_blank"
                              rel="noopener noreferrer"
                              aria-label={`View certificate for ${cert.title} (opens in new tab)`}
                              class="inline-flex cursor-pointer items-center gap-1.5 font-medium focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded"
                            >
                              View certificate
                            </a>
                          )}
                        </div>
                        {cert.certificateLink && (
                          <IconExternalLink size={12} aria-hidden="true" />
                        )}
                      </>
                    ) : (
                      <a
                        href={`/certificates/${cert.slug}`}
                        aria-label={`View notes for ${cert.title}`}
                        class="flex items-center justify-between w-full font-semibold hover:text-foreground decoration-muted-foreground/50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded"
                      >
                        <span>View notes</span>
                        <IconArrowRight size={16} aria-hidden="true" />
                      </a>
                    )}
                  </CardFooter>
                </Card>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <!-- Master Classes -->
    <section aria-labelledby="master-classes-heading">
      <p
        class="mb-1 font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
      >
        Explore
      </p>
      <h2
        id="master-classes-heading"
        class="text-2xl font-bold tracking-tight text-foreground mb-6"
      >
        Master Classes
      </h2>
      {
        masterClasses.length === 0 ? (
          <p class="text-muted-foreground">No master classes found.</p>
        ) : (
          <ul class="flex flex-col gap-4" role="list">
            {masterClasses.map((mc, i) => (
              <li
                class="index-card-wrap"
                style={`--stagger: ${certs.length + i}`}
              >
                <a
                  href={mc.path}
                  aria-label={`View notes for ${mc.title}`}
                  class="index-card group flex min-h-[3.5rem] cursor-pointer items-center justify-between rounded-xl border border-border bg-card px-5 py-4 text-sm shadow-sm transition-[border-color,box-shadow,background-color] duration-200 hover:border-primary/50 hover:bg-accent/50 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
                >
                  <span class="font-medium text-foreground group-hover:text-primary transition-colors duration-200">
                    {mc.title}
                  </span>
                  <span
                    class="text-muted-foreground text-xs transition-transform duration-200 group-hover:translate-x-0.5"
                    aria-hidden="true"
                  >
                    View notes →
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </article>
</Layout>

<style>
  .index-page {
    --stagger-step: 50ms;
  }

  .index-card-wrap {
    animation: index-fade-up 0.4s ease-out both;
    animation-delay: calc(var(--stagger) * var(--stagger-step));
  }

  @keyframes index-fade-up {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .index-card-wrap {
      animation: none;
      animation-delay: 0ms;
    }
  }
</style>
