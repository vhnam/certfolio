---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { buildCertList, buildMasterClassList } from "@/lib/navigation";
import CertificateCard from "@/components/CertificateCard.astro";
import MasterClassCard from "@/components/MasterClassCard.astro";

const certEntries = await getCollection("certificate").catch(() => []);
const masterClassEntries = await getCollection("masterClass").catch(() => []);
const certs = buildCertList(certEntries);
const masterClasses = buildMasterClassList(masterClassEntries).sort((a, b) =>
  a.title.localeCompare(b.title),
);
---

<Layout
  title="Homepage"
  description="Notes and learnings from professional certificates."
>
  <article class="index-page">
    <!-- Hero -->
    <header
      class="relative mb-16 overflow-hidden rounded-2xl border border-border/70 bg-background/70 supports-backdrop-filter:backdrop-blur-md px-6 py-12 shadow-[var(--shadow-md)] md:px-10 md:py-16"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,color-mix(in_oklab,var(--color-cta)_18%,transparent)_0%,transparent_70%)] opacity-70"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <p
          class="mb-3 font-mono text-sm font-medium uppercase tracking-widest text-muted-foreground"
        >
          Notes & learnings
        </p>
        <h1
          class="font-bold tracking-tight text-foreground text-[length:var(--text-h1)] leading-[1.05]"
        >
          Certfolio
        </h1>
        <div
          class="mt-4 h-1 w-16 rounded-full bg-[color:var(--color-cta)]"
          aria-hidden="true"
        >
        </div>
        <p
          class="mt-6 max-w-2xl leading-relaxed text-muted-foreground text-[length:var(--text-lead)]"
        >
          Structured notes and key learnings from professional design and
          technology certificates. Select a certificate below to explore the
          content.
        </p>
      </div>
    </header>

    <!-- Certificates -->
    <section class="mb-14" aria-labelledby="certificates-heading">
      <p
        class="mb-1 font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
      >
        Explore
      </p>
      <div class="mb-6 flex items-end justify-between gap-4">
        <h2
          id="certificates-heading"
          class="font-bold tracking-tight text-foreground text-[length:var(--text-h2)] leading-[1.15]"
        >
          Certificates
        </h2>
        <a
          href="/certificates/"
          class="shrink-0 inline-flex items-center gap-1.5 rounded-lg px-2 py-1 text-sm font-semibold text-[color:var(--color-cta)] underline-offset-4 transition-colors hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="View all certificates"
        >
          View all
          <span aria-hidden="true">→</span>
        </a>
      </div>
      {
        certs.length === 0 ? (
          <p class="text-muted-foreground">No certificates found.</p>
        ) : (
          <ul
            class="grid grid-cols-1 md:grid-cols-2 gap-6 auto-rows-auto"
            role="list"
          >
            {certs.map((cert, i) => (
              <li class="index-card-wrap" style={`--stagger: ${i}`}>
                <CertificateCard cert={cert} />
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <!-- Master Classes -->
    <section class="mb-14" aria-labelledby="master-classes-heading">
      <p
        class="mb-1 font-mono text-xs font-medium uppercase tracking-widest text-muted-foreground"
      >
        Explore
      </p>
      <div class="mb-2 flex items-end justify-between gap-4">
        <h2
          id="master-classes-heading"
          class="font-bold tracking-tight text-foreground text-[length:var(--text-h2)] leading-[1.15]"
        >
          Master Classes
        </h2>
        <a
          href="/master-classes/"
          class="shrink-0 inline-flex items-center gap-1.5 rounded-lg px-2 py-1 text-sm font-semibold text-[color:var(--color-cta)] underline-offset-4 transition-colors hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          aria-label="View all master classes"
        >
          View all
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="text-muted-foreground mb-6 max-w-2xl">
        Focused sessions and workshops from industry experts. Select one to view
        notes and takeaways.
      </p>
      {
        masterClasses.length === 0 ? (
          <p class="text-muted-foreground">No master classes found.</p>
        ) : (
          <ul
            class="grid grid-cols-1 md:grid-cols-2 gap-6 auto-rows-auto"
            role="list"
          >
            {masterClasses.map((mc, i) => (
              <li
                class="index-card-wrap"
                style={`--stagger: ${certs.length + i}`}
              >
                <MasterClassCard masterClass={mc} />
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </article>
</Layout>

<style>
  .index-page {
    --stagger-step: 50ms;
  }

  .index-card-wrap {
    animation: index-fade-up 0.4s ease-out both;
    animation-delay: calc(var(--stagger) * var(--stagger-step));
  }

  @keyframes index-fade-up {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .index-card-wrap {
      animation: none;
      animation-delay: 0ms;
    }
  }
</style>
