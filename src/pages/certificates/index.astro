---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { buildCertList } from "@/lib/navigation";
import CertificateCard from "@/components/CertificateCard.astro";

const certEntries = await getCollection("certificate").catch(() => []);
const certificatesList = buildCertList(certEntries);
---

<Layout title="Certificates">
  <div class="mb-12">
    <h1
      class="mb-4 font-bold tracking-tight text-foreground text-[length:var(--text-h1)] leading-[1.05]"
    >
      Certificates
    </h1>
    <p
      class="mb-10 leading-relaxed text-foreground/75 text-[length:var(--text-lead)]"
    >
      Structured notes and key learnings from professional design and technology
      certificates. Select a certificate below to explore the content.
    </p>
  </div>

  <ul class="grid grid-cols-1 md:grid-cols-2 gap-6" role="list">
    {
      certificatesList.map((cert) => (
        <li>
          <CertificateCard cert={cert} />
        </li>
      ))
    }
  </ul>
</Layout>
