---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { buildMasterClassList } from "@/lib/navigation";
import MasterClassCard from "@/components/MasterClassCard.astro";

const masterClassEntries = await getCollection("masterClass").catch(() => []);
const masterClasses = buildMasterClassList(masterClassEntries);
---

<Layout title="Master Classes">
  <div class="mb-12">
    <h1
      class="mb-4 font-bold tracking-tight text-foreground text-[length:var(--text-h1)] leading-[1.05]"
    >
      Master Classes
    </h1>
    <p
      class="mb-10 leading-relaxed text-foreground/75 text-[length:var(--text-lead)]"
    >
      Focused sessions and workshops from industry experts. Select a master
      class below to explore the content.
    </p>
  </div>

  {
    masterClasses.length === 0 ? (
      <p class="text-muted-foreground">No master classes found.</p>
    ) : (
      <ul
        class="grid grid-cols-1 md:grid-cols-2 gap-6 auto-rows-auto"
        role="list"
      >
        {masterClasses.map((mc, i) => (
          <li class="index-card-wrap" style={`--stagger: ${i}`}>
            <MasterClassCard masterClass={mc} />
          </li>
        ))}
      </ul>
    )
  }
</Layout>
