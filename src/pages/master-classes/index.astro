---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { buildMasterClassList } from "@/lib/navigation";

const masterClassEntries = await getCollection("masterClass").catch(() => []);
const masterClasses = buildMasterClassList(masterClassEntries);
---

<Layout title="Master Classes">
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      Master Classes
    </h1>
    <p class="text-xl text-gray-600 leading-relaxed dark:text-gray-300 mb-10">
      Focused sessions and workshops from industry experts. Select a master
      class below to explore the content.
    </p>
  </div>

  <ul class="flex flex-col gap-4" role="list">
    {
      masterClasses.map((mc) => (
        <li>
          <a
            href={mc.path}
            aria-label={`View notes for ${mc.title}`}
            class="index-card group flex min-h-[3.5rem] cursor-pointer items-center justify-between rounded-xl border border-border bg-card px-5 py-4 text-sm shadow-sm transition-[border-color,box-shadow,background-color] duration-200 hover:border-primary/50 hover:bg-accent/50 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
          >
            <span class="font-medium text-foreground group-hover:text-primary transition-colors duration-200">
              {mc.title}
            </span>
            <span
              class="text-muted-foreground text-xs transition-transform duration-200 group-hover:translate-x-0.5"
              aria-hidden="true"
            >
              View notes →
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>
