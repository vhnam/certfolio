---
import { MobileDrawer } from "@/components/MobileDrawer";
import { Search } from "@/components/Search";
import { ToggleTheme } from "@/components/ToggleTheme";
import type { CertRef, MasterClassRef, NavCertificate } from "@/lib/navigation";

interface Props {
  allCerts: CertRef[];
  allMasterClasses: MasterClassRef[];
  currentCert: NavCertificate | null;
  currentPath: string;
}

const { allCerts, allMasterClasses, currentCert, currentPath } = Astro.props;
---

<header
  id="site-header"
  class="flex items-center gap-3 border-b border-border bg-background/70 supports-backdrop-filter:backdrop-blur-md px-4 py-3 lg:px-6"
>
  <MobileDrawer
    client:load
    certificates={allCerts}
    masterClasses={allMasterClasses}
    currentCert={currentCert}
    currentPath={currentPath}
  />
  <a
    href="/"
    class="text-sm font-bold tracking-widest uppercase text-foreground hover:text-[color:var(--color-cta)] transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring focus-visible:rounded px-2 py-1"
  >
    Certfolio
  </a>

  <div class="ml-auto space-x-4">
    <Search client:load />
    <ToggleTheme client:load />
  </div>
</header>
